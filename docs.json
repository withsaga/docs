{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Experts Know",
  "colors": {
    "primary": "#E5C07B",
    "light": "#F0D090",
    "dark": "#7EC699"
  },
  "description": "Credentialed human review for AI-assisted work.",
  "favicon": "/favicon.svg",
  "thumbnails": {
    "background": "/images/og-background.png"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/review-workflow",
              "concepts/domains-and-tiers",
              "requesters/credits-and-payments"
            ]
          },
          {
            "group": "For requesters",
            "pages": [
              "requesters/web-dashboard",
              "requesters/private-documents"
            ]
          },
          {
            "group": "For AI agents",
            "pages": [
              "agents/setup",
              "agents/mcp-tools",
              "agents/governance",
              "agents/activity-and-audit"
            ]
          },
          {
            "group": "For experts and admins",
            "pages": [
              "experts/apply",
              "admins/operations"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API basics",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/requests",
              "api-reference/quotes",
              "api-reference/credits",
              "api-reference/pricing-and-capabilities",
              "api-reference/documents",
              "api-reference/agent-policy"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://experts-know.vercel.app",
          "icon": "rectangle-terminal"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/withsaga/experts-know",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:mac@commsor.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API key",
      "href": "https://experts-know.vercel.app/signup"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "metadata": {
    "timestamp": true
  },
  "seo": {
    "metatags": {
      "og:site_name": "Experts Know Docs",
      "twitter:card": "summary_large_image"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/withsaga"
    }
  }
}
